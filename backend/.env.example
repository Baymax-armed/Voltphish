# ─────────────────────────────────────────────────────────────
# PhishSim — example environment. Copy to .env for local dev.
# .env is gitignored (CLAUDE.md §3). Provide NO real secrets here.
# ─────────────────────────────────────────────────────────────

# App
PHISHSIM_ENV=development                 # development | production
PHISHSIM_SECRET_KEY=change-me-generate-a-64-char-random-value
PHISHSIM_DATABASE_URL=sqlite+pysqlite:///./phishsim.db

# Admin API server (private, authenticated)
PHISHSIM_ADMIN_HOST=127.0.0.1
PHISHSIM_ADMIN_PORT=8080

# Public URL that landing pages / tracking links resolve to.
# This is the base URL recipients' browsers hit. In a real deployment
# this is a domain you control and are AUTHORIZED to use for testing.
PHISHSIM_PHISH_BASE_URL=http://127.0.0.1:8080

# Cookies (production must be over HTTPS so Secure cookies work)
PHISHSIM_COOKIE_SECURE=false             # set true in production

# Email delivery backend: console | smtp
#   console -> writes .eml files to PHISHSIM_MAIL_OUTBOX (no real send; for testing)
#   smtp    -> uses a Sending Profile's SMTP config
PHISHSIM_MAIL_BACKEND=console
PHISHSIM_MAIL_OUTBOX=./outbox

# Ethical guardrail: never persist submitted passwords in the simulation.
# When true (default/recommended) we record THAT credentials were submitted
# but discard the password value. Set false only with documented authorization.
PHISHSIM_CAPTURE_PASSWORDS=false

# First-run admin bootstrap (used by seed.py only). Rotate immediately.
PHISHSIM_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
PHISHSIM_BOOTSTRAP_ADMIN_PASSWORD=
